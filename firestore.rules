rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Root admin — hardcoded emails, case-insensitive.
    // Uses auth token directly (no Firestore read), so it never fails.
    function isRootAdmin() {
      return isAuthenticated() &&
        request.auth.token.email.matches('(?i)^(david|office)@appout\\.co\\.il$');
    }

    // DB-backed admin — reads role field from user document.
    // Falls back to isRootAdmin() if the get() fails or field is missing.
    function isAdmin() {
      return isRootAdmin() ||
        (request.auth != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ============================================================
    // USERS — owner reads/writes own doc, admins read/write all,
    //         cross-user read gated by core.discoverable == true
    // ============================================================
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read, write: if isRootAdmin() || isAdmin();
      // Cross-user read: only if the profile has opted in to discovery
      allow read: if isAuthenticated() && resource.data.core.discoverable == true;

      // All sub-collections (progression, lifestyle, etc.)
      match /{subCol}/{docId} {
        allow read, write: if isOwner(userId);
        allow read, write: if isRootAdmin() || isAdmin();
      }
    }

    // ============================================================
    // ACTIVITY — daily activity logs, streaks (owned by user)
    // ============================================================
    match /dailyActivity/{docId} {
      allow read, write: if isAuthenticated();
    }

    // dailyProgress — docId format: {userId}_{date} (e.g. abc123_2025-02-21)
    // Authenticated users can read/write; docId prefix should match uid (enforced client-side)
    match /dailyProgress/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /streaks/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ============================================================
    // UTS — USER SCHEDULE (Phase 1)
    // Doc ID pattern: {userId}_{YYYY-MM-DD}
    // Users can only read/write their own schedule documents.
    // Admins can read/write all (for support & analytics).
    // Uses substring check: docId must start with "uid_".
    // ============================================================
    match /userSchedule/{docId} {
      allow read, write: if isRootAdmin() || isAdmin() ||
        (isAuthenticated() &&
         docId.size() > request.auth.uid.size() &&
         docId[0:request.auth.uid.size()] == request.auth.uid &&
         docId[request.auth.uid.size():request.auth.uid.size()+1] == '_');
    }

    // ============================================================
    // WORKOUTS — משתמש מחובר יכול ליצור/לקרוא אימונים
    // ============================================================
    match /workouts/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ============================================================
    // ANALYTICS — משתמש מחובר כותב אירועים
    // ============================================================
    match /analytics_events/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ============================================================
    // CONTENT — קריאה ציבורית (תרגילים, תוכניות, רמות, ציוד)
    // ============================================================
    match /exercises/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /levels/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /personas/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gear_definitions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gym_equipment/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /outdoorBrands/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // RUNNING ENGINE — תבניות אימוני ריצה + תוכניות + קונפיג
    // Public read so onboarding can generate plans for anonymous users.
    // ============================================================
    match /runWorkoutTemplates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /runProgramTemplates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // ONBOARDING & QUESTIONNAIRE — קריאה ציבורית, כתיבה לאדמין
    // ============================================================
    match /onboarding_questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /onboarding_answers/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // PROGRESSION ENGINE — קריאה ציבורית, כתיבה לאדמין
    // ============================================================
    match /progression_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // TEMPORARY: Allow write for Master Evolution Sync (API runs server-side without auth).
    // TODO: Revert to "allow write: if isAdmin();" after sync completes.
    match /program_level_settings/{docId} {
      allow read, write: if true;
    }

    // TEMPORARY: Same as above — used by programLevelSettings.service.ts
    match /programLevelSettings/{docId} {
      allow read, write: if true;
    }

    match /level_equivalence_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // APP CONFIG — הגדרות גלובליות (XP multipliers וכו׳)
    // ============================================================
    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // WORKOUT METADATA — תבניות, הודעות, תיאורים + תתי-אוספים
    // ============================================================
    match /workoutMetadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{subCollection}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Root-level metadata collections (used by workout-metadata.service)
    match /workoutTitles/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{sub}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /smartDescriptions/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{sub}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /motivationalPhrases/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{sub}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Workout content fragments & titles
    match /workout_content_fragments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_funny_titles/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_titles_creative/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_time_contexts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_focus_fragments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /time_contexts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /focus_descriptions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // PARKS, ROUTES, FACILITIES
    // ============================================================
    match /parks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /facilities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /official_routes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /curated_routes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // CRM / AUTHORITIES — public read for city lookups, admin write
    // Pillar 7: pressureCount is incrementable by authenticated users
    // ============================================================
    match /authorities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      // Users can increment pressureCount only (validated client-side with 24h dedup)
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pressureCount']);

      // pressure_logs sub-collection: any user can create, only admin reads
      match /pressure_logs/{logId} {
        allow read: if isAdmin();
        allow create: if isAuthenticated();
      }
    }

    // ============================================================
    // PRESSURE MESSAGES — dynamic message templates for league
    // ============================================================
    match /pressure_messages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // CATEGORY BRANDING — public read for facility icons
    // ============================================================
    match /category_branding/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // ADMIN — הזמנות, מדיה, עריכות, תחזוקה, ביקורת
    // ============================================================
    match /admin_invitations/{docId} {
      allow read, write: if isAdmin();
    }

    match /mediaAssets/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /edit_requests/{docId} {
      allow read, write: if isAdmin();
    }

    match /audit_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /maintenance_reports/{docId} {
      allow read, write: if isAdmin();
    }

    // ============================================================
    // SAFE-CITY PRESENCE — live location heartbeat
    // Users can only write their own presence doc (uid match).
    // Read access enforced by privacy mode:
    //   verified_global → any authenticated user
    //   squad           → only users in the broadcaster's followers list
    //   ghost           → owner only (doc is typically deleted)
    // ============================================================
    match /presence/{userId} {
      allow write: if isOwner(userId);
      allow read: if isOwner(userId);
      allow read: if isAuthenticated() && resource.data.mode == 'verified_global';
      allow read: if isAuthenticated()
                  && resource.data.mode == 'squad'
                  && request.auth.uid in
                     get(/databases/$(database)/documents/connections/$(userId)).data.followers;
    }

    // ============================================================
    // SOCIAL — connections graph + feed posts
    // ============================================================
    match /connections/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /feed_posts/{docId} {
      // Public posts: any authenticated user
      allow read: if isAuthenticated() && resource.data.audience == 'public';
      // Partners posts: any authenticated user (client query limits by authorUid list)
      allow read: if isAuthenticated() && resource.data.audience == 'partners';
      // Private: author only
      allow read: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
      // Legacy posts without audience field — allow read for backward compat
      allow read: if isAuthenticated() && !('audience' in resource.data);
      // Create: only for own posts
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.authorUid;
      allow update: if isAuthenticated();

      match /reactions/{reactionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ============================================================
    // COMMUNITY & ENGAGEMENT — Pillar 1/3
    // ============================================================
    match /community_groups/{docId} {
      allow read: if isAuthenticated();
      // Admins have full write access (authority-manager dashboard)
      allow write: if isAdmin();

      // Any authenticated user can create their own community group via the in-app wizard.
      // Guards:
      //   - request.auth.uid == createdBy  →  user can only create groups for themselves
      //   - source == 'user'               →  cannot impersonate authority/professional groups
      //   - isOfficial == false            →  cannot self-grant official status
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.createdBy
                    && request.resource.data.source == 'user'
                    && request.resource.data.isOfficial == false;

      // Creator can update their group (name, description, schedule, rules, images, etc.)
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.createdBy;

      // Any authenticated user can update only the membership counters when joining/leaving.
      // 'updatedAt' is included because group.service.ts writes it alongside the counters.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['memberCount', 'currentParticipants', 'updatedAt']);

      // group_members sub-collection — any authenticated user can join/leave their own doc
      match /members/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }

      // attendance sub-collection — session booking / RSVP
      match /attendance/{sessionId} {
        allow read, write: if request.auth != null;
      }
    }

    match /community_events/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      // Authenticated users can increment currentRegistrations (join/leave)
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['currentRegistrations', 'updatedAt']);

      // registrations sub-collection — users can write their own registration doc
      match /registrations/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // ============================================================
    // KUDOS — high-five inbox
    // ============================================================
    match /kudos/{recipientUid}/inbox/{kudoId} {
      allow read: if isOwner(recipientUid);
      allow create: if isAuthenticated();
      allow update: if isOwner(recipientUid);
    }

    // ============================================================
    // ACTIVITY FEED — Pillar 5
    // Users can read their own feed; users can write to their own
    // feed (join events) and to city-wide feeds (city_xxx).
    // ============================================================
    match /activity/{scopeId}/feed/{eventId} {
      allow read: if isAuthenticated()
                  && (isOwner(scopeId) || scopeId.matches('city_.*'));
      allow write: if isAdmin();
      allow create: if isAuthenticated()
                    && (request.auth.uid == scopeId
                        || scopeId.matches('city_.*'));
    }

    // ============================================================
    // DIRECT MESSAGES & GROUP CHATS — Pillar 5
    // ============================================================
    match /chats/{chatId} {
      // Existing participants can read their thread (DM + group)
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.participants;
      // Any authenticated user can read a group-type chat
      // (needed to check existence before joining and for inbox listing)
      allow read: if isAuthenticated()
                  && resource.data.type == 'group';

      // DM create: requesting user in participants, exactly 2 people
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2
                    && request.resource.data.type == 'dm';
      // Group chat create: requesting user in participants, type == 'group'
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.type == 'group';

      // Existing participants can update (send message metadata, mark read, etc.)
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants;
      // Group chat JOIN: any authenticated user can add themselves to a group chat.
      // After arrayUnion(uid), request.resource.data.participants will contain uid.
      allow update: if isAuthenticated()
                    && resource.data.type == 'group'
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        // Read: participant of the parent chat
        allow read: if isAuthenticated()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Create: sender must be themselves and be a participant
        allow create: if isAuthenticated()
                      && request.auth.uid == request.resource.data.senderUid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Update: only to add uid to readBy
        allow update: if isAuthenticated()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ============================================================
    // REPORTS — user-submitted content reports
    // create: any signed-in user (no helper functions — avoids get()
    //   evaluation side-effects from the catch-all isAdmin() rule)
    // read/manage: root admins + users whose role is admin/authority/root
    // ============================================================
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        request.auth.token.email.matches('(?i)^(david|office)@appout\\.co\\.il$') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'authority', 'root']
      );
    }

    // ============================================================
    // REFERRALS — tracking
    // ============================================================
    match /referrals/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /manager_notifications/{docId} {
      allow read, write: if isAdmin();
    }

    match /push_messages/{docId} {
      allow read, write: if isAdmin();
    }

    // ============================================================
    // PRODUCT ROADMAP & FEEDBACK
    // ============================================================
    match /product_roadmap/{docId} {
      allow read, write: if isAdmin();
    }

    match /product_tags/{docId} {
      allow read, write: if isAdmin();
    }

    match /user_feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ============================================================
    // SESSIONS — park check-ins
    // ============================================================
    match /sessions/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ============================================================
    // SCHOOLS / ORGANIZATIONS — code validation for B2E access
    // ============================================================
    match /schools/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // VISUAL ASSESSMENT SYSTEM — תוכן, חוקים, סף תוכניות
    // ============================================================
    match /visual_assessment_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assessment_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /program_thresholds/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // ADMIN FALLBACK — אדמין יכול לגשת לכל מסמך
    // ============================================================
    match /{document=**} {
      allow read, write: if isRootAdmin() || isAdmin();
    }
  }
}
