rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPERS
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Root admin — hardcoded emails, case-insensitive.
    // Uses auth token directly (no Firestore read), so it never fails.
    function isRootAdmin() {
      return isAuthenticated() &&
        request.auth.token.email.matches('(?i)^(david|office)@appout\\.co\\.il$');
    }

    // DB-backed admin — mirrors the multi-field check in resolveIdentity (firebase-admin.ts)
    // and checkUserRole (auth.service.ts).
    //
    // The app stores admin flags under `users/{uid}.core.*` (NOT as a top-level `role`
    // field). This helper reads all relevant fields so that any path that grants
    // Super Admin or System Admin privileges on the client also satisfies Firestore rules.
    //
    // Firestore caches repeated get() calls to the same document within a single request
    // evaluation, so calling getUserDoc() multiple times is equivalent to one read.
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isRootAdmin() ||
        (request.auth != null && (
          getUserDoc().role == 'admin' ||
          getUserDoc().get('core', {}).get('role', '') == 'admin' ||
          getUserDoc().get('core', {}).get('isSuperAdmin', false) == true ||
          getUserDoc().get('core', {}).get('isSystemAdmin', false) == true
        ));
    }

    // Tenant isolation — checks Custom Claim `tenantId` on the auth token.
    // Set via Admin SDK when assigning a user to a tenant.
    // Root/DB admins bypass tenant checks.
    function hasTenant(tenantId) {
      return isRootAdmin() || isAdmin() ||
        (isAuthenticated() && request.auth.token.tenantId == tenantId);
    }

    // ============================================================
    // USER-DOC PROTECTED-FIELD HELPERS
    //
    // The application reads admin/role flags from `users/{uid}.core.*`
    // (see src/features/admin/services/auth.service.ts → checkUserRole).
    // Because `affectedKeys()` is shallow, any owner could previously
    // self-promote by writing `{'core.isSuperAdmin': true}`. These helpers
    // close that hole by comparing each protected field byte-for-byte
    // before/after the update. Only writes that leave EVERY protected
    // field unchanged are allowed for non-admin owners.
    //
    // Admins (Admin SDK in Cloud Functions, or root/DB admin via console)
    // bypass these helpers via the separate `allow write` line below.
    // ============================================================

    // Group A — admin/role flags. These can ONLY be flipped by:
    //   • A Cloud Function using the Admin SDK (bypasses rules), or
    //   • A root/DB admin in the Firebase console.
    function noAdminFieldsChanged() {
      return request.resource.data.get('role', '')
             == resource.data.get('role', '')
          && request.resource.data.get('core', {}).get('role', '')
             == resource.data.get('core', {}).get('role', '')
          && request.resource.data.get('core', {}).get('isSuperAdmin', false)
             == resource.data.get('core', {}).get('isSuperAdmin', false)
          && request.resource.data.get('core', {}).get('isSystemAdmin', false)
             == resource.data.get('core', {}).get('isSystemAdmin', false)
          && request.resource.data.get('core', {}).get('isVerticalAdmin', false)
             == resource.data.get('core', {}).get('isVerticalAdmin', false)
          && request.resource.data.get('core', {}).get('isTenantOwner', false)
             == resource.data.get('core', {}).get('isTenantOwner', false)
          && request.resource.data.get('core', {}).get('isApproved', false)
             == resource.data.get('core', {}).get('isApproved', false)
          && request.resource.data.get('core', {}).get('managedVertical', '')
             == resource.data.get('core', {}).get('managedVertical', '');
    }

    // Group B — tenant/unit assignment. Owned by `validateAccessCode`
    // Cloud Function and admin tooling. Owners cannot self-assign.
    function noTenantFieldsChanged() {
      return request.resource.data.get('core', {}).get('tenantId', '')
             == resource.data.get('core', {}).get('tenantId', '')
          && request.resource.data.get('core', {}).get('tenantType', '')
             == resource.data.get('core', {}).get('tenantType', '')
          && request.resource.data.get('core', {}).get('unitId', '')
             == resource.data.get('core', {}).get('unitId', '')
          && request.resource.data.get('core', {}).get('unitPath', [])
             == resource.data.get('core', {}).get('unitPath', [])
          && request.resource.data.get('core', {}).get('authorityId', '')
             == resource.data.get('core', {}).get('authorityId', '');
    }

    // Group C — game-integrity / progression. Locking these prevents a
    // user from awarding themselves coins/levels via direct Firestore
    // writes from the browser console.
    //
    // The ONLY authorized writer for these fields is the
    // `awardWorkoutXP` Callable Cloud Function ("the Guardian"), which
    // uses the Admin SDK and therefore bypasses these rules. See
    // functions/src/awardWorkoutXP.ts for the server-side validation
    // (auth required, per-call delta caps, server-recomputed level).
    //
    // All client code paths that previously wrote these fields directly
    // were migrated as part of the Fortress Phase (Apr 2026). If a new
    // call site appears, route it through src/lib/awardWorkoutXP.ts —
    // do NOT relax this rule.
    function noGameIntegrityFieldsChanged() {
      return request.resource.data.get('progression', {}).get('coins', 0)
             == resource.data.get('progression', {}).get('coins', 0)
          && request.resource.data.get('progression', {}).get('globalLevel', 0)
             == resource.data.get('progression', {}).get('globalLevel', 0)
          && request.resource.data.get('progression', {}).get('globalXP', 0)
             == resource.data.get('progression', {}).get('globalXP', 0);
    }

    // Group D — passive sensor fields on `dailyActivity`. Native Phase
    // (Apr 2026): HealthKit / Health Connect samples are written ONLY
    // by the `ingestHealthSamples` Cloud Function (Admin SDK bypasses
    // these rules). Owners may still freely mutate manual-workout fields
    // on the same doc (categories.strength.minutes, etc.), but the
    // server-managed counters below are read-only from the client.
    //
    // We compare against the previous resource value when the doc exists,
    // and against 0 / serverTimestamp() when it does not — so a brand new
    // doc created by manual-workout client code can leave these fields
    // unset (== default) without tripping the guard.
    function noPassiveActivityFieldsChanged() {
      return request.resource.data.get('passiveSteps', 0)
             == resource.data.get('passiveSteps', 0)
          && request.resource.data.get('passiveCalories', 0)
             == resource.data.get('passiveCalories', 0)
          && request.resource.data.get('passiveActiveMinutes', 0)
             == resource.data.get('passiveActiveMinutes', 0)
          && request.resource.data.get('passiveXpAwardedToday', 0)
             == resource.data.get('passiveXpAwardedToday', 0);
    }

    // ============================================================
    // USERS — owner reads/writes own doc, admins read/write all,
    //         cross-user read gated by core.discoverable == true
    //
    // SECURITY (Fortress Phase — Deep Privilege Lockdown):
    //   The owner can NEVER mutate role/admin/tenant/progression flags.
    //   See helpers above for the exact field list and the Cloud-Function
    //   migration note for game-integrity fields.
    //   Admin role assignment must be done exclusively via:
    //     - Cloud Functions (Admin SDK bypasses these rules), or
    //     - Manual writes by a root/DB admin.
    // ============================================================
    match /users/{userId} {
      // READ — owner, admins, or any auth user when the profile opted into discovery.
      allow read: if isOwner(userId)
                  || isRootAdmin() || isAdmin()
                  || (isAuthenticated() && resource.data.core.discoverable == true);

      // CREATE — owner can create their own doc, but cannot self-assign
      // any role/admin flag at creation time. Tenant/progression fields
      // are allowed at create (validateAccessCode + initial seed need them).
      allow create: if isOwner(userId)
                    && !('role' in request.resource.data)
                    && request.resource.data.get('core', {}).get('isSuperAdmin', false) == false
                    && request.resource.data.get('core', {}).get('isSystemAdmin', false) == false
                    && request.resource.data.get('core', {}).get('isVerticalAdmin', false) == false
                    && request.resource.data.get('core', {}).get('isTenantOwner', false) == false
                    && request.resource.data.get('core', {}).get('isApproved', false) == false
                    && request.resource.data.get('core', {}).get('role', '') == ''
                    && request.resource.data.get('core', {}).get('managedVertical', '') == '';

      // UPDATE — owner may write everything EXCEPT the three protected
      // groups (admin/role, tenant, game-integrity). The Guardian
      // Cloud Function uses the Admin SDK to award XP/coins/calories
      // and bypasses Group C; see noGameIntegrityFieldsChanged() above.
      allow update: if isOwner(userId)
                    && noAdminFieldsChanged()
                    && noTenantFieldsChanged()
                    && noGameIntegrityFieldsChanged();

      // DELETE — owner can delete their own doc.
      allow delete: if isOwner(userId);

      // Admins (root or DB-backed) keep full read/write on the user doc,
      // including all protected groups — this is how admins are
      // promoted/demoted and how tenants are assigned in tooling.
      allow write: if isRootAdmin() || isAdmin();

      // Recursive wildcard — covers ALL sub-collections at ANY depth under users/{userId}.
      // This is required for nested paths like:
      //   exerciseHistory/{exerciseId}/sessions/{sessionId}   (getExerciseTrend)
      //   dailyStats/steps/sessions/{date}                     (future)
      // Without this rule, queries on 3+ level sub-collections fail with
      // "Missing or insufficient permissions".
      // Note: protected-field helpers only inspect the top-level user doc,
      // so granting owners full subtree write here does NOT enable
      // privilege escalation — none of those flags live in sub-collections.
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read, write: if isRootAdmin() || isAdmin();
      }
    }

    // ============================================================
    // ACTIVITY — daily activity logs, streaks (owned by user)
    // docId format: {userId}_{date}
    //
    // Two rule paths to cover both single-doc and collection-query access:
    //
    //   read  → resource.data.userId == uid
    //           Allows collection queries (WHERE userId == uid) because
    //           Firestore can tie this field check to the query's WHERE clause.
    //           Also covers single-doc reads when the doc exists.
    //
    //   write → request.resource.data.userId == uid
    //           Validates the incoming payload for creates and updates.
    //
    //   Both paths fall back to the docId prefix check (uid + '_') so that
    //   reads on non-existent docs and legacy paths still work.
    // ============================================================
    match /dailyActivity/{docId} {
      allow read, write: if isRootAdmin() || isAdmin();

      // Read: field check (enables collection queries) OR docId prefix
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (docId.size() > request.auth.uid.size() &&
         docId[0:request.auth.uid.size()] == request.auth.uid &&
         docId[request.auth.uid.size():request.auth.uid.size()+1] == '_')
      );

      // CREATE — owner check + passive fields must start at zero (or
      // be omitted). The ingestHealthSamples Cloud Function bypasses
      // this rule via Admin SDK, so server-side creation can still
      // populate passive counters directly.
      allow create: if isAuthenticated()
        && (
          request.resource.data.userId == request.auth.uid ||
          (docId.size() > request.auth.uid.size() &&
           docId[0:request.auth.uid.size()] == request.auth.uid &&
           docId[request.auth.uid.size():request.auth.uid.size()+1] == '_')
        )
        && request.resource.data.get('passiveSteps', 0) == 0
        && request.resource.data.get('passiveCalories', 0) == 0
        && request.resource.data.get('passiveActiveMinutes', 0) == 0
        && request.resource.data.get('passiveXpAwardedToday', 0) == 0;

      // UPDATE — owner check + passive sensor fields must not change.
      // Manual-workout client code can still freely update
      // categories.*.minutes, steps, calories, etc.
      allow update: if isAuthenticated()
        && (
          request.resource.data.userId == request.auth.uid ||
          (docId.size() > request.auth.uid.size() &&
           docId[0:request.auth.uid.size()] == request.auth.uid &&
           docId[request.auth.uid.size():request.auth.uid.size()+1] == '_')
        )
        && noPassiveActivityFieldsChanged();

      // DELETE — owner only.
      allow delete: if isAuthenticated()
        && (
          (resource != null && resource.data.userId == request.auth.uid) ||
          (docId.size() > request.auth.uid.size() &&
           docId[0:request.auth.uid.size()] == request.auth.uid &&
           docId[request.auth.uid.size():request.auth.uid.size()+1] == '_')
        );
    }

    // dailyProgress — same docId format: {userId}_{date}
    // Same dual-path pattern as dailyActivity above.
    match /dailyProgress/{docId} {
      allow read, write: if isRootAdmin() || isAdmin();

      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (docId.size() > request.auth.uid.size() &&
         docId[0:request.auth.uid.size()] == request.auth.uid &&
         docId[request.auth.uid.size():request.auth.uid.size()+1] == '_')
      );

      allow write: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        (docId.size() > request.auth.uid.size() &&
         docId[0:request.auth.uid.size()] == request.auth.uid &&
         docId[request.auth.uid.size():request.auth.uid.size()+1] == '_')
      );
    }

    // streaks — docId == uid
    match /streaks/{docId} {
      allow read, write: if isOwner(docId) || isRootAdmin() || isAdmin();
    }

    // ============================================================
    // HEALTH SAMPLES — raw HealthKit / Health Connect samples
    // (Native Phase, Apr 2026).
    //
    // Path: healthSamples/{userId}/{YYYY-MM-DD}/{sampleUUID}
    //
    // Writes are SERVER-ONLY: only the `ingestHealthSamples` Cloud
    // Function (Admin SDK bypasses these rules) may write here. This
    // protects the dedupe ledger from client tampering and ensures
    // every sample is validated + clamped before storage.
    //
    // Reads are owner-only (for debugging / future history views).
    // ============================================================
    match /healthSamples/{userId}/{date}/{sampleUUID} {
      allow read: if isOwner(userId) || isRootAdmin() || isAdmin();
      allow write: if isRootAdmin() || isAdmin();
    }
    // Parent doc holding the per-date subcollections — no client writes.
    match /healthSamples/{userId} {
      allow read: if isOwner(userId) || isRootAdmin() || isAdmin();
      allow write: if isRootAdmin() || isAdmin();
    }

    // ============================================================
    // UTS — USER SCHEDULE (Phase 1)
    // Doc ID pattern: {userId}_{YYYY-MM-DD}
    // Users can only read/write their own schedule documents.
    // Admins can read/write all (for support & analytics).
    // Uses substring check: docId must start with "uid_".
    // ============================================================
    match /userSchedule/{docId} {
      allow read, write: if isRootAdmin() || isAdmin() ||
        (isAuthenticated() &&
         docId.size() > request.auth.uid.size() &&
         docId[0:request.auth.uid.size()] == request.auth.uid &&
         docId[request.auth.uid.size():request.auth.uid.size()+1] == '_');
    }

    // ============================================================
    // WORKOUTS — owner access via userId field on document
    // ============================================================
    match /workouts/{docId} {
      allow read, write: if isRootAdmin() || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // ============================================================
    // SHARED WORKOUTS — public read for deep links,
    // authenticated create for sharing
    // ============================================================
    match /sharedWorkouts/{docId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.creatorId;
      allow write: if isRootAdmin() || isAdmin();
    }

    // ============================================================
    // ANALYTICS — משתמש מחובר כותב אירועים
    // ============================================================
    match /analytics_events/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ============================================================
    // CONTENT — קריאה ציבורית (תרגילים, תוכניות, רמות, ציוד)
    // ============================================================
    match /exercises/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /levels/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /personas/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gear_definitions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gym_equipment/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /outdoorBrands/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // RUNNING ENGINE — תבניות אימוני ריצה + תוכניות + קונפיג
    // Public read so onboarding can generate plans for anonymous users.
    // ============================================================
    match /runWorkoutTemplates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /runProgramTemplates/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // ONBOARDING & QUESTIONNAIRE — קריאה ציבורית, כתיבה לאדמין
    // ============================================================
    match /onboarding_questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /onboarding_answers/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // PROGRESSION ENGINE — קריאה ציבורית, כתיבה לאדמין
    // ============================================================
    match /progression_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SECURITY (C2 — Public Write defense):
    //   These collections were previously world-writable to support a
    //   "Master Evolution Sync" job. That assumption was wrong — Cloud
    //   Functions and Admin SDK calls bypass Firestore rules entirely, so
    //   server-side syncs do NOT require client-facing write permissions.
    //   Any anonymous or authenticated client could overwrite the workout
    //   engine's level/progression configuration → app-wide content corruption.
    //
    //   New policy:
    //     - read:  any authenticated user (the workout engine reads these client-side)
    //     - write: admins only (root or DB-backed)
    //   Server-side migration scripts continue to work via the Admin SDK.
    match /program_level_settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isRootAdmin() || isAdmin();
    }

    match /programLevelSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isRootAdmin() || isAdmin();
    }

    match /level_equivalence_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // APP CONFIG — הגדרות גלובליות (XP multipliers וכו׳)
    // ============================================================
    match /app_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // WORKOUT METADATA — תבניות, הודעות, תיאורים + תתי-אוספים
    // ============================================================
    match /workoutMetadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{subCollection}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Root-level metadata collections (used by workout-metadata.service)
    match /workoutTitles/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{sub}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /smartDescriptions/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{sub}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /motivationalPhrases/{docId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{sub}/{subDocId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Workout content fragments & titles
    match /workout_content_fragments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_funny_titles/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_titles_creative/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_time_contexts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /workout_focus_fragments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /time_contexts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /focus_descriptions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // PARKS, ROUTES, FACILITIES
    // ============================================================
    match /parks/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /facilities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /official_routes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      // Authenticated users may update ONLY the `analytics` sub-object
      // (e.g. usageCount, lastUsed) when completing a guided route.
      // Any write that touches another top-level field is rejected.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['analytics']);
    }

    match /curated_routes/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // STREET SEGMENTS — OSM-imported scored road/path segments
    // used by the dynamic route generator (fetchScoredWaypoints).
    // Public read so the client-side generator can query by city,
    // admin-only write (populated via the OSM importer script /
    // /admin/segments page).
    // ============================================================
    match /street_segments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // CRM / AUTHORITIES — public read for city lookups, admin write
    // Pillar 7: pressureCount is incrementable by authenticated users
    // ============================================================
    match /authorities/{docId} {
      allow read: if true;
      allow write: if isAdmin();
      // Users can increment pressureCount only (validated client-side with 24h dedup)
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pressureCount']);

      // pressure_logs sub-collection: any user can create, only admin reads
      match /pressure_logs/{logId} {
        allow read: if isAdmin();
        allow create: if isAuthenticated();
      }
    }

    // ============================================================
    // PRESSURE MESSAGES — dynamic message templates for league
    // ============================================================
    match /pressure_messages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // CATEGORY BRANDING — public read for facility icons
    // ============================================================
    match /category_branding/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // ADMIN — הזמנות, מדיה, עריכות, תחזוקה, ביקורת
    // ============================================================
    match /admin_invitations/{docId} {
      // Authenticated users can read invitations (needed for token validation
      // during the sign-up flow, before the user has the 'admin' role).
      // Tokens are 64-char random hex — knowledge of the token IS authorization.
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /mediaAssets/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /edit_requests/{docId} {
      allow read, write: if isAdmin();
    }

    // ============================================================
    // AUDIT LOGS — write-only via Cloud Function `logAuditAction`.
    //
    // Why direct client writes are blocked:
    //   • The Ashkelon Security Appendix (Req. 4.0) requires every
    //     audit row to record source IP. The client SDK cannot supply
    //     a trustworthy IP — anything it sends could be forged.
    //   • The `logAuditAction` Callable Cloud Function captures the
    //     real edge IP from `rawRequest.headers['x-forwarded-for']`
    //     and writes via the Admin SDK, bypassing these rules.
    //   • Read access stays admin-only per legacy.
    //
    // Net effect: NO client (regular user OR admin) can `addDoc` here
    // directly — they must call the function. Admin reads still work.
    // ============================================================
    match /audit_logs/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /maintenance_reports/{docId} {
      allow read, write: if isAdmin();
    }

    // ============================================================
    // ACTIVE WORKOUTS — live heatmap heartbeat (45s ephemeral docs)
    // Users write/delete their own doc (uid match). Admins read all
    // docs for their authority via the heatmap aggregation service.
    // ============================================================
    match /active_workouts/{userId} {
      allow write: if isOwner(userId);
      allow delete: if isOwner(userId);
      allow read: if isAdmin();
      allow read: if isOwner(userId);
    }

    // ============================================================
    // SAFE-CITY PRESENCE — live location heartbeat
    // Users can only write their own presence doc (uid match).
    // Read access enforced by privacy mode:
    //   verified_global → any authenticated user
    //   squad           → only users in the broadcaster's followers list
    //   ghost           → owner only (doc is typically deleted)
    // ============================================================
    match /presence/{userId} {
      allow write: if isOwner(userId);
      allow read: if isOwner(userId);
      allow read: if isAuthenticated() && resource.data.mode == 'verified_global';
      allow read: if isAuthenticated()
                  && resource.data.mode == 'squad'
                  && request.auth.uid in
                     get(/databases/$(database)/documents/connections/$(userId)).data.followers;
    }

    // ============================================================
    // SOCIAL — connections graph + feed posts
    // ============================================================
    match /connections/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followers', 'following', 'followerCount', 'followingCount', 'updatedAt']);
    }

    match /feed_posts/{docId} {
      // Public posts: any authenticated user
      allow read: if isAuthenticated() && resource.data.audience == 'public';
      // Partners posts: any authenticated user (client query limits by authorUid list)
      allow read: if isAuthenticated() && resource.data.audience == 'partners';
      // Private: author only
      allow read: if isAuthenticated() && request.auth.uid == resource.data.authorUid;
      // Legacy posts without audience field — allow read for backward compat
      allow read: if isAuthenticated() && !('audience' in resource.data);
      // Create: only for own posts
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.authorUid;

      // SECURITY (H1 — Feed Integrity):
      //   Update is restricted to the original author. The previous rule
      //   (`allow update: if isAuthenticated()`) let any logged-in user
      //   rewrite or deface any other user's post, including the authorUid
      //   field itself. The author check uses `resource.data.authorUid`
      //   (the EXISTING doc, not the incoming payload) so an attacker cannot
      //   spoof authorship by sending a forged `authorUid` in the request.
      //
      //   We additionally lock the `authorUid` field — even the rightful
      //   author cannot change post ownership after creation.
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.authorUid
                    && request.resource.data.authorUid == resource.data.authorUid;

      // Delete: only the original author can remove their own post (GDPR /
      // Israeli Privacy Law compliance — users own their UGC and can erase
      // it). Authorship is checked against `resource.data.authorUid` (the
      // existing doc) so an attacker cannot spoof by sending a forged
      // payload. Compliance Phase 3.2.
      allow delete: if isAuthenticated()
                    && request.auth.uid == resource.data.authorUid;

      match /reactions/{reactionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ============================================================
    // COMMUNITY & ENGAGEMENT — Pillar 1/3
    // ============================================================
    match /community_groups/{docId} {
      allow read: if isAuthenticated();
      // Admins have full write access (authority-manager dashboard)
      allow write: if isAdmin();

      // Any authenticated user can create their own community group via the in-app wizard.
      // Guards:
      //   - request.auth.uid == createdBy  →  user can only create groups for themselves
      //   - source == 'user'               →  cannot impersonate authority/professional groups
      //   - isOfficial == false            →  cannot self-grant official status
      allow create: if isAuthenticated()
                    && request.auth.uid == request.resource.data.createdBy
                    && request.resource.data.source == 'user'
                    && request.resource.data.isOfficial == false;

      // Creator can update their group (name, description, schedule, rules, images, etc.)
      allow update: if isAuthenticated()
                    && request.auth.uid == resource.data.createdBy;

      // Any authenticated user can update only the membership counters when joining/leaving.
      // 'updatedAt' is included because group.service.ts writes it alongside the counters.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['memberCount', 'currentParticipants', 'updatedAt']);

      // group_members sub-collection — any authenticated user can join/leave their own doc
      match /members/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }

      // attendance sub-collection — session booking / RSVP.
      // Any authenticated member can read attendance, but writes are scoped
      // to the user's own record only (sessionId == uid convention).
      match /attendance/{sessionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated()
                     && request.auth.uid == sessionId;
      }
    }

    match /community_events/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      // Authenticated users can increment currentRegistrations (join/leave)
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['currentRegistrations', 'updatedAt']);

      // registrations sub-collection — users can write their own registration doc
      match /registrations/{uid} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // ============================================================
    // KUDOS — high-five inbox
    // ============================================================
    match /kudos/{recipientUid}/inbox/{kudoId} {
      allow read: if isOwner(recipientUid);
      allow create: if isAuthenticated();
      allow update: if isOwner(recipientUid);
    }

    // ============================================================
    // ACTIVITY FEED — Pillar 5
    // Users can read their own feed; users can write to their own
    // feed (join events) and to city-wide feeds (city_xxx).
    // ============================================================
    match /activity/{scopeId}/feed/{eventId} {
      allow read: if isAuthenticated()
                  && (isOwner(scopeId) || scopeId.matches('city_.*'));
      allow write: if isAdmin();
      allow create: if isAuthenticated()
                    && (request.auth.uid == scopeId
                        || scopeId.matches('city_.*'));
    }

    // ============================================================
    // DIRECT MESSAGES & GROUP CHATS — Pillar 5
    // ============================================================
    match /chats/{chatId} {
      // Existing participants can read their thread (DM + group)
      allow read: if isAuthenticated()
                  && request.auth.uid in resource.data.participants;
      // Any authenticated user can read a group-type chat
      // (needed to check existence before joining and for inbox listing)
      allow read: if isAuthenticated()
                  && resource.data.type == 'group';

      // DM create: requesting user in participants, exactly 2 people.
      //
      // SECURITY (Compliance Phase 2.2 — Minor DM Block):
      //   Both participants must have core.ageGroup == 'adult'. Minors
      //   (under 18) cannot initiate or be added to a DM. ageGroup is
      //   set server-side in onboarding-sync.service.ts from the user's
      //   birthDate (re-validated in the sync service, see Phase 2.1).
      //
      //   Defensive .get() calls — if the user doc or core.ageGroup field
      //   is missing, the comparison fails ('' != 'adult') and creation is
      //   denied. Legacy users without ageGroup must re-onboard or be
      //   backfilled by admin tooling before they can create new DMs.
      //
      //   NOTE: This rule covers DM creation only. Group chats (`type ==
      //   'group'`) are handled by a separate allow-create rule below; the
      //   group-chat case is intentionally left open until tenant-scoped
      //   group rules are added.
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2
                    && request.resource.data.type == 'dm'
                    && get(/databases/$(database)/documents/users/$(request.resource.data.participants[0]))
                         .data.get('core', {}).get('ageGroup', '') == 'adult'
                    && get(/databases/$(database)/documents/users/$(request.resource.data.participants[1]))
                         .data.get('core', {}).get('ageGroup', '') == 'adult';
      // Group chat create: requesting user in participants, type == 'group'
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.type == 'group';

      // Existing participants can update (send message metadata, mark read, etc.)
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.participants;
      // Group chat JOIN: any authenticated user can add themselves to a group chat.
      // After arrayUnion(uid), request.resource.data.participants will contain uid.
      allow update: if isAuthenticated()
                    && resource.data.type == 'group'
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        // Read: participant of the parent chat
        allow read: if isAuthenticated()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Create: sender must be themselves and be a participant
        allow create: if isAuthenticated()
                      && request.auth.uid == request.resource.data.senderUid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Update: only to add uid to readBy
        allow update: if isAuthenticated()
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // ============================================================
    // REPORTS — user-submitted content reports
    // create: any signed-in user (no helper functions — avoids get()
    //   evaluation side-effects from the catch-all isAdmin() rule)
    // read/manage: root admins + users whose role is admin/authority/root
    // ============================================================
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        request.auth.token.email.matches('(?i)^(david|office)@appout\\.co\\.il$') ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'authority', 'root']
      );
    }

    // ============================================================
    // REFERRALS — tracking
    // ============================================================
    match /referrals/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    match /manager_notifications/{docId} {
      allow read, write: if isAdmin();
    }

    match /push_messages/{docId} {
      allow read, write: if isAdmin();
    }

    // ============================================================
    // PRODUCT ROADMAP & FEEDBACK
    // ============================================================
    match /product_roadmap/{docId} {
      allow read, write: if isAdmin();
    }

    match /product_tags/{docId} {
      allow read, write: if isAdmin();
    }

    match /user_feedback/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // ============================================================
    // SESSIONS — park check-ins
    // ============================================================
    match /sessions/{docId} {
      allow read, write: if isAuthenticated();
    }

    // ============================================================
    // SCHOOLS / ORGANIZATIONS — code validation for B2E access
    // ============================================================
    match /schools/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // ACCESS CODES — validated exclusively by Cloud Function.
    // Clients may read to check existence; only the CF increments
    // usageCount via Admin SDK (bypasses rules).
    // ============================================================
    match /access_codes/{codeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============================================================
    // PE GRADES — teacher grading (docId: {uid}_{term})
    // Teachers (admin) write; students read their own grades.
    // ============================================================
    match /pe_grades/{docId} {
      allow read, write: if isRootAdmin() || isAdmin();
      allow read: if isAuthenticated() &&
        docId.size() > request.auth.uid.size() &&
        docId[0:request.auth.uid.size()] == request.auth.uid &&
        docId[request.auth.uid.size():request.auth.uid.size()+1] == '_';
    }

    // ============================================================
    // READINESS CONFIGS — military fitness thresholds per unit
    // Tenant-isolated: only users in the same tenant can read.
    // ============================================================
    match /readiness_configs/{unitId} {
      allow read: if isAuthenticated() &&
        hasTenant(resource.data.tenantId);
      allow write: if isAdmin();
    }

    // ============================================================
    // LEADERBOARD SHARDS — distributed counters (written by CF)
    // Clients should not write directly; reads are tenant-scoped.
    // ============================================================
    match /leaderboard_shards/{shardId} {
      allow read: if isAuthenticated();
      allow write: if isRootAdmin() || isAdmin();
    }

    // ============================================================
    // LEADERBOARD SNAPSHOTS — rolled-up rankings (written by CF)
    // Read-only for authenticated users; tenant-scoped.
    // ============================================================
    match /leaderboard_snapshots/{snapshotId} {
      allow read: if isAuthenticated();
      allow write: if isRootAdmin() || isAdmin();
    }

    // ============================================================
    // TENANTS & UNITS — multi-tenant hierarchy
    // Tenant reads gated by Custom Claim. Admins can write.
    // ============================================================
    match /tenants/{tenantId} {
      allow read: if hasTenant(tenantId);
      allow write: if isAdmin();

      match /units/{unitId} {
        allow read: if hasTenant(tenantId);
        allow write: if isAdmin();
      }
    }

    // ============================================================
    // VISUAL ASSESSMENT SYSTEM — תוכן, חוקים, סף תוכניות
    // ============================================================
    match /visual_assessment_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assessment_rules/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /program_thresholds/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ============================================================
    // USER CONTRIBUTIONS — Community Intelligence reports & edits
    // ============================================================
    match /user_contributions/{docId} {
      // Create: only for own contributions
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;

      // Owner reads their own contributions (reports, edits, reviews)
      allow read: if isAuthenticated()
        && request.auth.uid == resource.data.userId;

      // Reviews are public park content — any authenticated user can read
      allow read: if isAuthenticated()
        && resource.data.type == 'review';

      // Admin full access
      allow read, update, delete: if isRootAdmin() || isAdmin();
    }

    // ============================================================
    // SYSTEM CONFIG — feature flags (real-time app toggles)
    // Public read: feature flags are not sensitive data and must load
    // immediately for anonymous / pre-auth users without permission errors.
    // Only Root Admins / Super Admins may write.
    // ============================================================
    match /system_config/{docId} {
      allow read: if true;
      allow write: if isRootAdmin() || isAdmin();
    }

    // ============================================================
    // ADMIN FALLBACK — אדמין יכול לגשת לכל מסמך
    // ============================================================
    match /{document=**} {
      allow read, write: if isRootAdmin() || isAdmin();
    }
  }
}
