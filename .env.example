# ============================================================================
# OUT-RUN — Environment Variables Template
# ============================================================================
# Copy this file to `.env.local` and fill in the values you need.
#
#   cp .env.example .env.local
#
# `.env.local` is gitignored (`.gitignore` has `.env*.local`) so secrets
# never leave your machine. `vercel env pull` will OVERWRITE this file
# wholesale — keep this `.env.example` as the canonical reference so you
# can rebuild `.env.local` after a sync.
#
# Every key referenced in this template was discovered with:
#   rg "process\.env\." src
# Keep them in sync if you add a new variable.
# ============================================================================


# ── REQUIRED for the app to render ──────────────────────────────────────────
# Without this, every Mapbox component throws
# `An API access token is required` and the entire map blanks.
# Pull from: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Firebase App Check — public reCAPTCHA Enterprise site key (production).
# Required in production for App Check enforcement on Firestore/Storage.
# Pull from: https://console.firebase.google.com → App Check → reCAPTCHA Enterprise
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=


# ── OPTIONAL (dev-only / feature flags) ─────────────────────────────────────
# App Check debug token — bypasses reCAPTCHA in development. Get one from
# the Firebase console (App Check → Apps → Manage debug tokens).
# Leave blank in production.
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# Comma-separated emails treated as root admins by `feature-flags.ts`.
# Optional — leave blank to use the Firestore-side role table only.
NEXT_PUBLIC_ROOT_ADMIN_EMAILS=

# Bunny CDN — public-side IDs (browser uses these to build asset URLs).
# Falls back to the server-only equivalents below if blank.
NEXT_PUBLIC_BUNNY_LIBRARY_ID=
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=


# ── SERVER-ONLY (never exposed to the browser, no NEXT_PUBLIC_ prefix) ──────
# Firebase Admin SDK service account JSON (single-line, escaped).
# Used by `src/lib/firebase-admin.ts` for server-side auth/Firestore/RBAC.
FIREBASE_SERVICE_ACCOUNT_KEY=

# Symmetric secret used to sign the admin session cookie. Any random
# 32+ char string is fine in dev; rotate in production.
SESSION_COOKIE_SECRET=

# Bunny CDN — server-side credentials. The `bunny.config.ts` reader
# prefers the `NEXT_PUBLIC_*` variants for browser code and falls back
# to these for API routes.
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=


# ── AUTO-INJECTED by Vercel (do NOT set manually) ───────────────────────────
# `vercel env pull` writes this; the build picks it up automatically.
# VERCEL_OIDC_TOKEN=
